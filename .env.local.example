# ---- Staff area PIN ----
# Protects /kitchen and /tables (and the order API). Defaults to 4288 if unset.
# Set your own before going live.
# STAFF_PIN=4288

# ---- Database (Supabase) ----
# Persists orders + bookings. Without these, the app uses an in-memory store
# (fine for local dev, but data is lost on restart and won't work on serverless).
# 1) Create a free project at https://supabase.com
# 2) Run supabase/schema.sql in the SQL editor
# 3) Copy these from Project Settings → API:
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=   # service_role secret — server only, never expose

# ---- Notifications (optional) ----
# Fill in to send reservation email/SMS (stubs no-op until set).
# RESEND_API_KEY=          # transactional email
# TWILIO_ACCOUNT_SID=      # SMS confirmation
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
